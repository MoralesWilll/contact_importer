<h1>Imported Contacts</h1>

<% if @contacts.any? %>
  <div class="overflow-x-auto">
    <table class="min-w-full bg-white border border-gray-300">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 border-b text-left">Name</th>
          <th class="px-4 py-2 border-b text-left">Date of Birth</th>
          <th class="px-4 py-2 border-b text-left">Phone</th>
          <th class="px-4 py-2 border-b text-left">Credit Card (Last 4)</th>
          <th class="px-4 py-2 border-b text-left">Address</th>
          <th class="px-4 py-2 border-b text-left">Email</th>
        </tr>
      </thead>
      <tbody>
        <% @contacts.each do |contact| %>
          <tr class="hover:bg-gray-50">
            <td class="px-4 py-2 border-b"><%= contact.name %></td>
            <td class="px-4 py-2 border-b"><%= contact.date_of_birth %></td>
            <td class="px-4 py-2 border-b"><%= contact.phone %></td>
            <td class="px-4 py-2 border-b"><%= contact.credit_card_last_four %></td>
            <td class="px-4 py-2 border-b"><%= contact.address %></td>
            <td class="px-4 py-2 border-b"><%= contact.email %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-gray-600 mb-4">No contacts found. Try importing some!</p>
<% end %>

<%= link_to "Import Contacts via CSV", new_contact_import_path, class: "inline-block bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded shadow mt-4" %>