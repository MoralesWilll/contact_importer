<%= form_with model: ContactImport.new, url: contact_imports_path, method: :post, multipart: true, html: { class: "import-form space-y-8 max-w-xl mx-auto bg-white p-8 rounded shadow" } do |form| %>
  <div>
    <label for="contact_import_csv_file" class="block font-semibold mb-2 text-gray-700">Select CSV File:</label>
    <%= form.file_field :csv_file, class: "block w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500", id: "contact_import_csv_file" %>
  </div>

  <div>
    <h3 class="text-lg font-bold mb-4 text-gray-800">Map Columns</h3>
    <p class="text-sm text-gray-600 mb-4">Enter either the column header name or column index (0-based) for each field:</p>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4">
      <% %w[name date_of_birth phone address email credit_card_number].each do |field| %>
        <div>
          <label for="contact_import_column_mapping_<%= field %>" class="block mb-1 text-gray-700">
            <%= field.humanize %> Column:
          </label>
          <%= form.text_field "column_mapping[#{field}]", 
                placeholder: "e.g. '#{field.humanize}' or '0'", 
                class: "w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500",
                id: "contact_import_column_mapping_#{field}" %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="bg-yellow-50 border border-yellow-200 rounded p-4">
    <h4 class="font-semibold text-yellow-800 mb-2">Expected Data Formats:</h4>
    <ul class="text-sm text-yellow-700 space-y-1">
      <li><strong>Date of Birth:</strong> YYYYMMDD or YYYY-MM-DD</li>
      <li><strong>Phone:</strong> (+XX) XXX-XXX-XX-XX format</li>
      <li><strong>Name:</strong> Letters, spaces, and hyphens only</li>
      <li><strong>Email:</strong> Valid email format</li>
    </ul>
  </div>

  <div class="flex space-x-4">
    <%= form.submit "Process Now", name: "commit", value: "now", class: "w-1/2 bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-4 rounded shadow transition" %>
    <%= form.submit "Process in Background", name: "commit", value: "background", class: "w-1/2 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-4 rounded shadow transition" %>
  </div>
<% end %>